# Copy to news_blackouts.yaml (git-ignored). Times are UTC.
# During a blackout window, new entries are skipped for all symbols;
# existing positions keep running normally.

windows:
  - start: "2026-04-30T14:30:00"
    end:   "2026-04-30T15:00:00"
    label: "CPI release"
  - start: "2026-05-07T18:00:00"
    end:   "2026-05-07T18:30:00"
    label: "FOMC decision"
